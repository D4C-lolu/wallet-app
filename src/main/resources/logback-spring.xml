<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Read Loki host from environment, default to localhost for local dev -->
    <springProperty name="LOKI_HOST" source="loki.host" defaultValue="localhost"/>

    <!-- ANSI Color Codes -->
    <conversionRule conversionWord="clr"
                    class="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    class="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>

    <!-- Color mapping per log level -->
    <property name="GREY"   value="%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint}"/>
    <property name="APP"    value="%clr([${springAppName:-app}]){cyan}"/>
    <property name="THREAD" value="%clr([%15.15t]){faint}"/>
    <property name="LOGGER" value="%clr(%-40.40logger{39}){cyan}"/>

    <!-- ═══════════════════════════════════════════════
         CONSOLE (coloured) — dev only
         ═══════════════════════════════════════════════ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${GREY} ${APP} ${THREAD} %clr(%-5level){ERROR=bold_red, WARN=yellow, INFO=green, DEBUG=blue, TRACE=faint} %clr([traceId=%X{traceId:-NO_TRACE}]){magenta} %clr([spanId=%X{spanId:-NO_SPAN}]){yellow} ${LOGGER} : %msg%n%wex</pattern>
        </encoder>
    </appender>

    <!-- ═══════════════════════════════════════════════
         CONSOLE (plain) — prod only
         ═══════════════════════════════════════════════ -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} [%15.15t] %-5level [traceId=%X{traceId:-NO_TRACE}] [spanId=%X{spanId:-NO_SPAN}] %-40.40logger{39} : %msg%n%wex</pattern>
        </encoder>
    </appender>

    <!-- ═══════════════════════════════════════════════
         LOKI — Loki4j 2.0.x format
         ═══════════════════════════════════════════════ -->
    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <batchMaxItems>1000</batchMaxItems>
        <batchMaxBytes>4194304</batchMaxBytes>
        <batchTimeoutMs>10000</batchTimeoutMs>
        <sendQueueMaxBytes>41943040</sendQueueMaxBytes>

        <http>
            <url>http://${LOKI_HOST}:3100/loki/api/v1/push</url>
        </http>

        <labels>
            <pattern>app=wallet-app,level=%level</pattern>
        </labels>

        <message>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [traceId=%X{traceId:-NO_TRACE}] [spanId=%X{spanId:-NO_SPAN}] %logger{39} : %msg%n%wex</pattern>
        </message>
    </appender>

    <!-- ═══════════════════════════════════════════════
         PROFILES
         ═══════════════════════════════════════════════ -->

    <!-- Dev: DEBUG, coloured console + Loki -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

    <!-- Prod: INFO, plain console + Loki -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

    <!-- Fallback (no profile set): INFO, coloured console + Loki -->
    <springProfile name="!(dev | prod)">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

</configuration>